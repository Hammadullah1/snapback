<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/snap_scrim">

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/overlay_card_bg"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_title"
            android:textColor="@color/snap_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/overlay_loading"
            android:textColor="@color/snap_text_primary"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.3"/>

        <TextView
            android:id="@+id/helpline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/overlay_helpline"
            android:textColor="@color/snap_danger"
            android:textSize="14sp"
            android:visibility="gone"/>

        <EditText
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/overlay_input_bg"
            android:hint="@string/overlay_hint"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:padding="12dp"
            android:textColor="@color/snap_text_primary"
            android:textColorHint="@color/snap_text_secondary"
            android:textSize="15sp"
            android:autofillHints="off"
            android:importantForAutofill="no"/>

        <TextView
            android:id="@+id/inputHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Type 5 characters to unlock"
            android:textColor="@color/snap_text_secondary"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/overlay_button_primary"
                android:text="@string/overlay_done"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:enabled="false"
                android:alpha="0.5"/>

            <Button
                android:id="@+id/btnSnooze"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/overlay_button_outline"
                android:text="@string/overlay_snooze"
                android:textColor="@color/snap_text_primary"
                android:textAllCaps="false"
                android:enabled="false"
                android:alpha="0.5"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
